<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.modules.system.mapper.UserMapper">

    <!-- 用户VO结果映射 -->
    <resultMap id="UserVOResultMap" type="com.fast.modules.system.domain.dto.UserVO">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="nickname" column="nickname"/>
        <result property="avatar" column="avatar"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="gender" column="gender"/>
        <result property="status" column="status"/>
        <result property="deptId" column="dept_id"/>
        <result property="deptName" column="dept_name"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 分页查询用户列表 -->
    <select id="selectUserPage" resultMap="UserVOResultMap">
        SELECT u.id, u.username, u.nickname, u.avatar, u.email, u.phone, u.gender, u.status, u.dept_id, u.create_time,
               d.dept_name
        FROM sys_user u
        LEFT JOIN sys_dept d ON u.dept_id = d.id
        WHERE u.del_flag = '0'
        <if test="query.deptId != null">
            AND u.dept_id = #{query.deptId}
        </if>
        <if test="query.username != null and query.username != ''">
            AND u.username LIKE CONCAT('%', #{query.username}, '%')
        </if>
        <if test="query.phone != null and query.phone != ''">
            AND u.phone LIKE CONCAT('%', #{query.phone}, '%')
        </if>
        <if test="query.status != null and query.status != ''">
            AND u.status = #{query.status}
        </if>
        <if test="query.dataScope != null and query.dataScope != ''">
            ${query.dataScope}
        </if>
        ORDER BY u.create_time DESC
    </select>

    <!-- 查询用户列表（不分页，用于导出） -->
    <select id="selectUserList" resultMap="UserVOResultMap">
        SELECT u.id, u.username, u.nickname, u.avatar, u.email, u.phone, u.gender, u.status, u.dept_id, u.create_time,
               d.dept_name
        FROM sys_user u
        LEFT JOIN sys_dept d ON u.dept_id = d.id
        WHERE u.del_flag = '0'
        <if test="query.deptId != null">
            AND u.dept_id = #{query.deptId}
        </if>
        <if test="query.username != null and query.username != ''">
            AND u.username LIKE CONCAT('%', #{query.username}, '%')
        </if>
        <if test="query.phone != null and query.phone != ''">
            AND u.phone LIKE CONCAT('%', #{query.phone}, '%')
        </if>
        <if test="query.status != null and query.status != ''">
            AND u.status = #{query.status}
        </if>
        <if test="query.dataScope != null and query.dataScope != ''">
            ${query.dataScope}
        </if>
        ORDER BY u.create_time DESC
    </select>

    <!-- 批量插入用户角色关联 -->
    <insert id="insertUserRole">
        INSERT INTO sys_user_role (user_id, role_id) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{userId}, #{roleId})
        </foreach>
    </insert>

    <!-- 删除用户角色关联 -->
    <delete id="deleteUserRoleByUserId">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>

    <!-- 根据角色ID查询用户ID列表 -->
    <select id="selectUserIdsByRoleId" resultType="string">
        SELECT ur.user_id FROM sys_user_role ur
        INNER JOIN sys_user u ON ur.user_id = u.id
        WHERE ur.role_id = #{roleId} AND u.del_flag = '0' AND u.status = '0'
    </select>

    <!-- 根据部门ID查询用户ID列表 -->
    <select id="selectUserIdsByDeptId" resultType="string">
        SELECT id FROM sys_user
        WHERE dept_id = #{deptId} AND del_flag = '0' AND status = '0'
    </select>

    <!-- 批量查询用户角色 -->
    <select id="selectRolesByUserIds" resultType="com.fast.modules.system.domain.dto.RoleVO">
        SELECT r.id, r.role_name, r.role_key, ur.user_id
        FROM sys_role r
        INNER JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id IN
        <foreach collection="list" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
        AND r.del_flag = '0'
    </select>

</mapper>