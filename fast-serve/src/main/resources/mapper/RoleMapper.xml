<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.modules.system.mapper.RoleMapper">


    <!-- 根据用户ID查询角色列表 -->
    <select id="selectRolesByUserId" resultType="com.fast.modules.system.domain.entity.Role">
        SELECT r.*
        FROM sys_role r
        LEFT JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND r.del_flag = '0'
        ORDER BY r.role_sort
    </select>


    <!-- 批量插入角色菜单关联 -->
    <insert id="insertRoleMenu">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId})
        </foreach>
    </insert>

    <!-- 批量插入角色部门关联 -->
    <insert id="insertRoleDept">
        INSERT INTO sys_role_dept (role_id, dept_id) VALUES
        <foreach collection="deptIds" item="deptId" separator=",">
            (#{roleId}, #{deptId})
        </foreach>
    </insert>


    <!-- 删除角色菜单关联 -->
    <delete id="deleteRoleMenuByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 删除角色部门关联 -->
    <delete id="deleteRoleDeptByRoleId">
        DELETE FROM sys_role_dept WHERE role_id = #{roleId}
    </delete>

    <!-- 检查角色是否已分配给用户 -->
    <select id="countUsersByRoleId" resultType="int">
        SELECT COUNT(1) FROM sys_user_role WHERE role_id = #{roleId}
    </select>

</mapper>